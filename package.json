{
  "name": "buddagatchi",
  "version": "0.1.0",
  "description": "Your Claude Code buddy, living on your desktop as a tamagotchi. Farts when you close your laptop.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-builder",
    "build:dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "electron-store": "^10.0.0"
  },
  "build": {
    "appId": "com.eschnei.buddagatchi",
    "productName": "Buddagatchi",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": "dmg",
      "identity": null
    },
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "electron-builder": "^25.1.0",
    "typescript": "^5.7.0"
  }
}
